declare(strict_types=1);

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Cache\Cache;
use Drupal\Core\Config\FileStorage;
use Drupal\Core\Datetime\DrupalDateTime;
use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function paragraph_bundle_alert_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.paragraph_bundle_alert') {
    return paragraphs_bundles__helper_render_readme();
  }
  return NULL;
}

/**
 * Implements hook_theme().
 */
function paragraph_bundle_alert_theme($existing, $type, $theme, $path) {
  return [
    'paragraph__alert_bundle' => [
      'base hook' => 'paragraph',
    ],
  ];
}

/**
 * Implements hook_field_widget_single_element_form_alter().
 *
 * Force the site's default timezone on alert date-range fields so all users
 * see and enter dates in the same timezone regardless of personal settings.
 */
function paragraph_bundle_alert_field_widget_single_element_form_alter(array &$element, FormStateInterface $form_state, array $context): void {
  $field_name = $context['items']->getFieldDefinition()->getName();
  if (!in_array($field_name, ['pb_display_alert_start_date', 'pb_display_alert_end_date'], TRUE)) {
    return;
  }
  $site_timezone = \Drupal::config('system.date')->get('timezone.default') ?: 'UTC';
  if (isset($element['value'])) {
    $element['value']['#date_timezone'] = $site_timezone;
    $element['value']['#description'] = t('Timezone: @tz', ['@tz' => $site_timezone]);
    // The widget creates #default_value (a DrupalDateTime) in the user's
    // timezone BEFORE this hook runs. Re-zone it to the site timezone so
    // the displayed time matches #date_timezone.
    if (!empty($element['value']['#default_value']) && $element['value']['#default_value'] instanceof DrupalDateTime) {
      $element['value']['#default_value']->setTimezone(new \DateTimeZone($site_timezone));
    }
  }
}

/**
 * Implements hook_preprocess_page().
 *
 * Attach admin-only JS for conditional display of alert form fields on admin.
 */
function paragraph_bundle_alert_preprocess_page(&$variables): void {
  $admin_context = \Drupal::service('router.admin_context');
  if ($admin_context->isAdminRoute()) {
    $variables['#attached']['library'][] = 'paragraph_bundle_alert/paragraph-bundle-alert-admin';
  }
}

/**
 * Create field configs from YAML files in config/optional.
 *
 * @param string $module_name
 *   The module name (e.g. 'paragraph_bundle_alert').
 * @param array $config_names
 *   Config names to create (e.g. field.storage.paragraph.*).
 */
function _paragraph_bundle_alert_update_fields_from_yml(string $module_name, array $config_names): void {
  $module_handler = \Drupal::moduleHandler();
  $config_storage = new FileStorage(
    $module_handler->getModule($module_name)->getPath() . '/config/optional'
  );

  foreach ($config_names as $config_name) {
    $existing = \Drupal::configFactory()->get($config_name);
    if (!$existing->isNew()) {
      \Drupal::logger('paragraph_bundle_alert')->notice('Config @name already exists, skipping', ['@name' => $config_name]);
      continue;
    }

    $config_record = $config_storage->read($config_name);
    if (!$config_record) {
      \Drupal::logger('paragraph_bundle_alert')->warning('Config file @name not found', ['@name' => $config_name]);
      continue;
    }

    $entity_type = \Drupal::service('config.manager')->getEntityTypeIdByName($config_name);
    $storage = \Drupal::entityTypeManager()->getStorage($entity_type);
    $entity = $storage->createFromStorageRecord($config_record);
    $entity->save();

    \Drupal::logger('paragraph_bundle_alert')->notice('Created config @name', ['@name' => $config_name]);
  }
}

/**
 * Install new alert fields (dismissal type, date range, countdown, persist).
 */
function paragraph_bundle_alert_update_8101(): string {
  $messages = [];

  $field_configs = [
    'field.storage.paragraph.pb_display_alert_dismissal_type',
    'field.storage.paragraph.pb_display_alert_start_date',
    'field.storage.paragraph.pb_display_alert_end_date',
    'field.storage.paragraph.pb_display_alert_countdown_sec',
    'field.storage.paragraph.pb_display_alert_show_cdown_lbl',
    'field.storage.paragraph.pb_display_alert_close_persist',
    'field.field.paragraph.alert_bundle.pb_display_alert_dismissal_type',
    'field.field.paragraph.alert_bundle.pb_display_alert_start_date',
    'field.field.paragraph.alert_bundle.pb_display_alert_end_date',
    'field.field.paragraph.alert_bundle.pb_display_alert_countdown_sec',
    'field.field.paragraph.alert_bundle.pb_display_alert_show_cdown_lbl',
    'field.field.paragraph.alert_bundle.pb_display_alert_close_persist',
  ];

  _paragraph_bundle_alert_update_fields_from_yml('paragraph_bundle_alert', $field_configs);
  $messages[] = t('Created field storages and field instances for alert dismissal, date range, countdown, and close persist.');

  // Add only the new field components to the form display; preserve existing
  // content order and field_group (same approach as slideshow).
  $form_display = \Drupal::entityTypeManager()->getStorage('entity_form_display')->load('paragraph.alert_bundle.default');
  if ($form_display) {
    $content = $form_display->get('content');
    $new_components = [
      'pb_display_alert_dismissal_type' => [
        'type' => 'options_select',
        'weight' => 30,
        'region' => 'content',
        'settings' => [],
        'third_party_settings' => [],
      ],
      'pb_display_alert_start_date' => [
        'type' => 'datetime_default',
        'weight' => 31,
        'region' => 'content',
        'settings' => [],
        'third_party_settings' => [],
      ],
      'pb_display_alert_end_date' => [
        'type' => 'datetime_default',
        'weight' => 32,
        'region' => 'content',
        'settings' => [],
        'third_party_settings' => [],
      ],
      'pb_display_alert_countdown_sec' => [
        'type' => 'number',
        'weight' => 33,
        'region' => 'content',
        'settings' => [
          'placeholder' => '',
          'min' => 1,
          'max' => 86400,
          'step' => 1,
        ],
        'third_party_settings' => [],
      ],
      'pb_display_alert_show_cdown_lbl' => [
        'type' => 'boolean_checkbox',
        'weight' => 34,
        'region' => 'content',
        'settings' => ['display_label' => TRUE],
        'third_party_settings' => [],
      ],
      'pb_display_alert_close_persist' => [
        'type' => 'options_select',
        'weight' => 35,
        'region' => 'content',
        'settings' => [],
        'third_party_settings' => [],
      ],
    ];
    foreach ($new_components as $name => $component) {
      if (!isset($content[$name])) {
        $content[$name] = $component;
      }
    }
    $form_display->set('content', $content);

    // Append the new fields to the Display tab (group_tab_display) children
    // so they appear in the same order and weight.
    $tps = $form_display->get('third_party_settings');
    $new_field_names = [
      'pb_display_alert_dismissal_type',
      'pb_display_alert_start_date',
      'pb_display_alert_end_date',
      'pb_display_alert_countdown_sec',
      'pb_display_alert_show_cdown_lbl',
      'pb_display_alert_close_persist',
    ];
    if (isset($tps['field_group']['group_tab_display']['children'])) {
      $children = $tps['field_group']['group_tab_display']['children'];
      foreach ($new_field_names as $name) {
        if (!in_array($name, $children, TRUE)) {
          $children[] = $name;
        }
      }
      $tps['field_group']['group_tab_display']['children'] = $children;
      $form_display->set('third_party_settings', $tps);
    }
    $form_display->save();
    $messages[] = t('Added new alert fields to form display and Display tab.');
  }

  // Add only the new fields to the view display hidden list.
  $view_display = \Drupal::entityTypeManager()->getStorage('entity_view_display')->load('paragraph.alert_bundle.default');
  if ($view_display) {
    $hidden = $view_display->get('hidden');
    $new_hidden_fields = [
      'pb_display_alert_dismissal_type',
      'pb_display_alert_start_date',
      'pb_display_alert_end_date',
      'pb_display_alert_countdown_sec',
      'pb_display_alert_show_cdown_lbl',
      'pb_display_alert_close_persist',
    ];
    foreach ($new_hidden_fields as $name) {
      $hidden[$name] = TRUE;
    }
    $view_display->set('hidden', $hidden);
    $view_display->save();
    $messages[] = t('Added new alert fields to view display (hidden).');
  }

  \Drupal::service('plugin.manager.field.widget')->clearCachedDefinitions();
  \Drupal::service('plugin.manager.field.formatter')->clearCachedDefinitions();
  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();

  \Drupal::messenger()->addMessage(t('Alert bundle updated: new fields for dismissal type, date range, countdown, and "don\'t show again today/session" have been installed.'));

  return implode(' ', $messages);
}

/**
 * Installs title tag + alignment for alert_bundle (storages live in paragraphs_bundles).
 */
function paragraph_bundle_alert_update_8102(): string {
  paragraphs_bundles_ensure_pb_title_storages();
  paragraphs_bundles_pb_title_import_instances_for_bundle('paragraph_bundle_alert', 'alert_bundle');
  paragraphs_bundles_pb_title_wire_bundle('alert_bundle');
  paragraphs_bundles_clear_field_caches();
  return (string) t('Installed title tag and alignment for alert_bundle.');
}

/**
 * Implements hook_preprocess_paragraph() for alert_bundle.
 */
function paragraph_bundle_alert_preprocess_paragraph__alert_bundle(array &$variables): void {
  $paragraph = $variables['paragraph'];
  if ($paragraph->bundle() !== 'alert_bundle') {
    return;
  }

  $variables['pb_default_state'] = 'open';
  $variables['pb_alert_hidden'] = FALSE;

  if (!$paragraph->hasField('pb_display_alert_dismissal_type')) {
    return;
  }

  $dismissal_type = $paragraph->get('pb_display_alert_dismissal_type')->value ?? 'none';
  $variables['pb_dismissal_type'] = $dismissal_type;
  $variables['pb_countdown_seconds'] = 0;
  if ($paragraph->hasField('pb_display_alert_countdown_sec') && !$paragraph->get('pb_display_alert_countdown_sec')->isEmpty()) {
    $variables['pb_countdown_seconds'] = (int) $paragraph->get('pb_display_alert_countdown_sec')->value;
  }
  $variables['pb_show_countdown_label'] = $paragraph->hasField('pb_display_alert_show_cdown_lbl')
    && !$paragraph->get('pb_display_alert_show_cdown_lbl')->isEmpty()
    && $paragraph->get('pb_display_alert_show_cdown_lbl')->value;
  $variables['pb_close_persist'] = $paragraph->hasField('pb_display_alert_close_persist')
    ? ($paragraph->get('pb_display_alert_close_persist')->value ?? 'none')
    : 'none';

  // Pass end timestamp to JS so it can auto-hide when the page is open.
  $variables['pb_date_range_end'] = 0;

  if ($dismissal_type === 'date_range') {
    $start = $paragraph->get('pb_display_alert_start_date')->value ?? NULL;
    $end = $paragraph->get('pb_display_alert_end_date')->value ?? NULL;
    // Drupal stores datetime as UTC (e.g. '2026-02-22T10:00:00').
    // Use DrupalDateTime which natively understands this storage format.
    $utc = new \DateTimeZone('UTC');
    $now_ts = time();
    $start_ts = 0;
    $end_ts = 0;
    if ($start) {
      $start_dt = new DrupalDateTime($start, $utc);
      if (!$start_dt->hasErrors()) {
        $start_ts = $start_dt->getTimestamp();
      }
    }
    if ($end) {
      $end_dt = new DrupalDateTime($end, $utc);
      if (!$end_dt->hasErrors()) {
        $end_ts = $end_dt->getTimestamp();
      }
    }

    if ($start_ts && $end_ts && $start_ts > $end_ts) {
      // Invalid range: start after end → hide.
      $variables['pb_alert_hidden'] = TRUE;
      $variables['pb_default_state'] = 'closed';
    }
    elseif ($start_ts && $now_ts < $start_ts) {
      // Before start date → hide; expire cache when start date arrives.
      $variables['pb_alert_hidden'] = TRUE;
      $variables['pb_default_state'] = 'closed';
      $max_age = $start_ts - $now_ts;
      $current = $variables['#cache']['max-age'] ?? Cache::PERMANENT;
      $variables['#cache']['max-age'] = Cache::mergeMaxAges($current, $max_age);
    }
    elseif ($end_ts && $now_ts > $end_ts) {
      // Past end date → hide permanently (no cache adjustment needed).
      $variables['pb_alert_hidden'] = TRUE;
      $variables['pb_default_state'] = 'closed';
    }
    else {
      // Alert is visible. Pass end timestamp to JS for client-side auto-hide.
      $variables['pb_date_range_end'] = $end_ts;
      // If there is an end date, expire cache when it arrives.
      if ($end_ts && $now_ts <= $end_ts) {
        $max_age = $end_ts - $now_ts;
        $current = $variables['#cache']['max-age'] ?? Cache::PERMANENT;
        $variables['#cache']['max-age'] = Cache::mergeMaxAges($current, $max_age);
      }
    }
  }
}
