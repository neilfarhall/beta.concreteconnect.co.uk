use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function paragraph_bundle_views_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.paragraph_bundle_views') {
    return paragraphs_bundles__helper_render_readme();
  }
  return NULL;
}

/**
 * Implements hook_theme() for the paragraph_bundle_views submodule.
 */
function paragraph_bundle_views_theme($existing, $type, $theme, $path) {
  $template_directory = \Drupal::service('extension.path.resolver')->getPath('module', 'paragraphs_bundles') . '/templates';

  return [
    'paragraph__views_bundle' => [
      'base hook' => 'paragraph',
      'template' => 'paragraph--default',
      'path' => $template_directory,
    ],
  ];
}

/**
 * Implements hook_theme_suggestions_paragraph_alter() for views.
 */
function paragraph_bundle_views_theme_suggestions_paragraph_alter(array &$suggestions, array $variables) {
  /** @var \Drupal\paragraphs\Entity\Paragraph $paragraph */
  $paragraph = $variables['elements']['#paragraph'];
  $bundle = $paragraph->bundle();

  // Add a template suggestion for paragraphs of type 'views_bundle'.
  if ($bundle === 'views_bundle') {
    $suggestions[] = 'paragraph__views_bundle';
  }
}

/**
 * Installs title tag + alignment for views_bundle (storages live in paragraphs_bundles).
 */
function paragraph_bundle_views_update_8001(): string {
  paragraphs_bundles_ensure_pb_title_storages();
  paragraphs_bundles_pb_title_import_instances_for_bundle('paragraph_bundle_views', 'views_bundle');
  paragraphs_bundles_pb_title_wire_bundle('views_bundle');
  paragraphs_bundles_clear_field_caches();
  return (string) t('Installed title tag and alignment for views_bundle.');
}
