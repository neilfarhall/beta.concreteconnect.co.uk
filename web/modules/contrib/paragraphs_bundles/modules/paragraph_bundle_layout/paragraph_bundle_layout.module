declare(strict_types=1);

use Drupal\Core\Config\FileStorage;
use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function paragraph_bundle_layout_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.paragraph_bundle_layout') {
    return paragraphs_bundles__helper_render_readme();
  }
  return NULL;
}

/**
 * Implements hook_theme().
 */
function paragraph_bundle_layout_theme($existing, $type, $theme, $path) {
  return [
    'paragraph__one_column_bundle' => [
      'base hook' => 'paragraph',
    ],
    'paragraph__two_columns_bundle' => [
      'base hook' => 'paragraph',
    ],
    'paragraph__three_columns_bundle' => [
      'base hook' => 'paragraph',
    ],
  ];
}

/**
 * Create field configs from YAML files in config/optional.
 */
function _paragraph_bundle_layout_update_fields_from_yml(string $module_name, array $config_names): void {
  $module_handler = \Drupal::moduleHandler();
  $config_storage = new FileStorage(
    $module_handler->getModule($module_name)->getPath() . '/config/optional'
  );

  foreach ($config_names as $config_name) {
    $existing = \Drupal::configFactory()->get($config_name);
    if (!$existing->isNew()) {
      continue;
    }

    $config_record = $config_storage->read($config_name);
    if (!$config_record) {
      continue;
    }

    $entity_type = \Drupal::service('config.manager')->getEntityTypeIdByName($config_name);
    if ($entity_type === NULL) {
      continue;
    }
    $storage = \Drupal::entityTypeManager()->getStorage($entity_type);
    $entity = $storage->createFromStorageRecord($config_record);
    $entity->save();
  }
}

/**
 * Install interactive column controls for two/three columns bundles.
 *
 * Also fixes animation select: require field and rename "none" label to
 * "No animation" (removes duplicate None in the widget).
 */
function paragraph_bundle_layout_update_8101(): string {
  $messages = [];
  $two_fields = [
    'pb_display_2c_l_tgl',
    'pb_display_2c_r_tgl',
    'pb_display_2c_l_def',
    'pb_display_2c_r_def',
    'pb_display_2c_l_stk',
    'pb_display_2c_r_stk',
    'pb_display_2c_stk_top',
    'pb_display_2c_icn',
    'pb_display_2c_icn_pos',
    'pb_display_2c_anim',
    'pb_display_2c_anim_ms',
    'pb_display_2c_expand',
  ];
  $three_fields = [
    'pb_display_3c_l_tgl',
    'pb_display_3c_m_tgl',
    'pb_display_3c_r_tgl',
    'pb_display_3c_l_def',
    'pb_display_3c_m_def',
    'pb_display_3c_r_def',
    'pb_display_3c_l_stk',
    'pb_display_3c_m_stk',
    'pb_display_3c_r_stk',
    'pb_display_3c_stk_top',
    'pb_display_3c_icn',
    'pb_display_3c_icn_pos',
    'pb_display_3c_anim',
    'pb_display_3c_anim_ms',
    'pb_display_3c_expand',
  ];

  $field_configs = [];
  foreach (array_merge($two_fields, $three_fields) as $field_name) {
    $field_configs[] = 'field.storage.paragraph.' . $field_name;
  }
  foreach ($two_fields as $field_name) {
    $field_configs[] = 'field.field.paragraph.two_columns_bundle.' . $field_name;
  }
  foreach ($three_fields as $field_name) {
    $field_configs[] = 'field.field.paragraph.three_columns_bundle.' . $field_name;
  }
  _paragraph_bundle_layout_update_fields_from_yml('paragraph_bundle_layout', $field_configs);
  $messages[] = t('Created new interactive layout field storages and field instances.');

  $bundle_components = [
    'two_columns_bundle' => $two_fields,
    'three_columns_bundle' => $three_fields,
  ];
  foreach ($bundle_components as $bundle => $fields) {
    $form_display = \Drupal::entityTypeManager()->getStorage('entity_form_display')->load('paragraph.' . $bundle . '.default');
    if ($form_display) {
      $content = $form_display->get('content');
      $weight = 33;
      foreach ($fields as $name) {
        if (!isset($content[$name])) {
          $component = [
            'type' => 'options_select',
            'weight' => $weight,
            'region' => 'content',
            'settings' => [],
            'third_party_settings' => [],
          ];
          if (str_ends_with($name, '_tgl') || str_ends_with($name, '_stk') || str_ends_with($name, '_expand')) {
            $component['type'] = 'boolean_checkbox';
            $component['settings'] = ['display_label' => TRUE];
          }
          elseif (str_ends_with($name, '_ms') || str_ends_with($name, '_top')) {
            $component['type'] = 'number';
            $component['settings'] = ['placeholder' => ''];
          }
          $content[$name] = $component;
        }
        $weight++;
      }
      $form_display->set('content', $content);

      $tps = $form_display->get('third_party_settings');
      if (isset($tps['field_group']['group_pb_tab_display']['children'])) {
        $children = $tps['field_group']['group_pb_tab_display']['children'];
        foreach ($fields as $name) {
          if (!in_array($name, $children, TRUE)) {
            $children[] = $name;
          }
        }
        $tps['field_group']['group_pb_tab_display']['children'] = $children;
        $form_display->set('third_party_settings', $tps);
      }
      $form_display->save();
    }

    $view_display = \Drupal::entityTypeManager()->getStorage('entity_view_display')->load('paragraph.' . $bundle . '.default');
    if ($view_display) {
      $hidden = $view_display->get('hidden');
      foreach ($fields as $name) {
        if (!isset($hidden[$name])) {
          $hidden[$name] = TRUE;
        }
      }
      $view_display->set('hidden', $hidden);
      $view_display->save();
    }
  }

  // Animation field: require (avoids duplicate "None" in select) + rename label if still old.
  foreach ([
    'field.field.paragraph.two_columns_bundle.pb_display_2c_anim',
    'field.field.paragraph.three_columns_bundle.pb_display_3c_anim',
  ] as $config_name) {
    $config = \Drupal::configFactory()->getEditable($config_name);
    if ($config->isNew()) {
      continue;
    }
    if (!$config->get('required')) {
      $config->set('required', TRUE);
      $config->save();
    }
  }
  foreach ([
    'field.storage.paragraph.pb_display_2c_anim',
    'field.storage.paragraph.pb_display_3c_anim',
  ] as $storage_name) {
    $config = \Drupal::configFactory()->getEditable($storage_name);
    if ($config->isNew()) {
      continue;
    }
    $settings = $config->get('settings');
    if (!isset($settings['allowed_values']) || !is_array($settings['allowed_values'])) {
      continue;
    }
    $changed = FALSE;
    foreach ($settings['allowed_values'] as $i => $row) {
      if (is_array($row) && ($row['value'] ?? '') === 'none' && ($row['label'] ?? '') === 'None') {
        $settings['allowed_values'][$i]['label'] = 'No animation';
        $changed = TRUE;
      }
    }
    if ($changed) {
      $config->set('settings', $settings);
      $config->save();
    }
  }

  \Drupal::service('plugin.manager.field.widget')->clearCachedDefinitions();
  \Drupal::service('plugin.manager.field.formatter')->clearCachedDefinitions();
  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();

  $messages[] = t('Added interactive column fields to two/three display tabs and view hidden lists.');
  $messages[] = t('Toggle animation effect: required field; "none" option labeled No animation when needed.');
  return implode(' ', $messages);
}

/**
 * Rename toggle icon position: inside_top → edge_top, Edge → Edge center.
 */
function paragraph_bundle_layout_update_8102(): string {
  $messages = [];

  // Update allowed_values in field storage configs.
  foreach ([
    'field.storage.paragraph.pb_display_2c_icn_pos',
    'field.storage.paragraph.pb_display_3c_icn_pos',
  ] as $storage_name) {
    $config = \Drupal::configFactory()->getEditable($storage_name);
    if ($config->isNew()) {
      continue;
    }
    $settings = $config->get('settings');
    if (!isset($settings['allowed_values']) || !is_array($settings['allowed_values'])) {
      continue;
    }
    $new_values = [];
    foreach ($settings['allowed_values'] as $row) {
      if (is_array($row)) {
        if (($row['value'] ?? '') === 'inside_top') {
          $row['value'] = 'edge_top';
          $row['label'] = 'Edge top';
        }
        elseif (($row['value'] ?? '') === 'edge') {
          $row['label'] = 'Edge center';
        }
      }
      $new_values[] = $row;
    }
    $settings['allowed_values'] = $new_values;
    $config->set('settings', $settings);
    $config->save();
  }
  $messages[] = t('Updated icon position allowed values: inside_top → edge_top, Edge → Edge center.');

  // Migrate stored field data from inside_top to edge_top.
  $database = \Drupal::database();
  $field_tables = [
    'pb_display_2c_icn_pos' => [
      'paragraph__pb_display_2c_icn_pos',
      'paragraph_revision__pb_display_2c_icn_pos',
    ],
    'pb_display_3c_icn_pos' => [
      'paragraph__pb_display_3c_icn_pos',
      'paragraph_revision__pb_display_3c_icn_pos',
    ],
  ];
  foreach ($field_tables as $field_name => $tables) {
    $column = $field_name . '_value';
    foreach ($tables as $table) {
      if ($database->schema()->tableExists($table)) {
        $database->update($table)
          ->fields([$column => 'edge_top'])
          ->condition($column, 'inside_top')
          ->execute();
      }
    }
  }
  $messages[] = t('Migrated existing inside_top values to edge_top.');

  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();

  return implode(' ', $messages);
}

/**
 * Installs title tag + alignment for one/two/three column bundles only (this module).
 */
function paragraph_bundle_layout_update_8103(): string {
  paragraphs_bundles_ensure_pb_title_storages();
  $module = 'paragraph_bundle_layout';
  foreach (['one_column_bundle', 'two_columns_bundle', 'three_columns_bundle'] as $bundle) {
    paragraphs_bundles_pb_title_import_instances_for_bundle($module, $bundle);
    paragraphs_bundles_pb_title_wire_bundle($bundle);
  }
  paragraphs_bundles_clear_field_caches();
  return (string) t('Installed title tag and alignment fields for one, two, and three column layout bundles.');
}
