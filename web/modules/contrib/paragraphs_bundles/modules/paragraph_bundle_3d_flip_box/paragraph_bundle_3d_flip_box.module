use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function paragraph_bundle_3d_flip_box_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.paragraph_bundle_3d_flip_box') {
    return paragraphs_bundles__helper_render_readme();
  }
  return NULL;
}

/**
 * Implements hook_theme().
 */
function paragraph_bundle_3d_flip_box_theme($existing, $type, $theme, $path) {
  return [
    'paragraph__3d_flip_box_bundle' => [
      'base hook' => 'paragraph',
    ],
  ];
}

/**
 * Installs title tag + alignment for 3d_flip_box_bundle (storages live in paragraphs_bundles).
 */
function paragraph_bundle_3d_flip_box_update_8001(): string {
  paragraphs_bundles_ensure_pb_title_storages();
  paragraphs_bundles_pb_title_import_instances_for_bundle('paragraph_bundle_3d_flip_box', '3d_flip_box_bundle');
  paragraphs_bundles_pb_title_wire_bundle('3d_flip_box_bundle');
  paragraphs_bundles_clear_field_caches();
  return (string) t('Installed title tag and alignment for 3d_flip_box_bundle.');
}
