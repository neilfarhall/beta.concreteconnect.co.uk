use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function paragraph_bundle_image_help($route_name, RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.paragraph_bundle_image') {
    return paragraphs_bundles__helper_render_readme();
  }
  return NULL;
}

/**
 * Implements hook_theme().
 */
function paragraph_bundle_image_theme($existing, $type, $theme, $path) {
  return [
    'paragraph__image_bundle' => [
      'base hook' => 'paragraph',
    ],
    'paragraph__image_wide_bundle' => [
      'base hook' => 'paragraph',
    ],
    'paragraph__image_narrow_bundle' => [
      'base hook' => 'paragraph',
    ],
  ];
}

/**
 * Installs title tag + alignment for image bundles (storages live in paragraphs_bundles).
 */
function paragraph_bundle_image_update_8001(): string {
  paragraphs_bundles_ensure_pb_title_storages();
  $module = 'paragraph_bundle_image';
  foreach (['image_bundle', 'image_narrow_bundle', 'image_wide_bundle'] as $bundle) {
    paragraphs_bundles_pb_title_import_instances_for_bundle($module, $bundle);
    paragraphs_bundles_pb_title_wire_bundle($bundle);
  }
  paragraphs_bundles_clear_field_caches();
  return (string) t('Installed title tag and alignment for image, image narrow, and image wide bundles.');
}
