{#
/**
 * @file
 * Template for Navbar component.
 *
 * Available blocks:
 * - branding
 * - left
 * - right
 */
#}
{% set nav_attributes = nav_attributes ?: create_attribute() %}
{% set navbar_container_attributes = navbar_container_attributes ?: create_attribute() %}

{% set placement = placement ?? '' %}
{% set navbar_expand = navbar_expand ?? 'lg' %}
{% set navbar_theme = 'dark' %}

{%
  set navbar_container_classes = [
  navbar_container_type is null ? 'container' : '',
  navbar_container_type ? 'container' ~ (navbar_container_type ? '-' ~ navbar_container_type : '') : '',
]|merge(navbar_container_utility_classes ?: [])
%}

{%
  set nav_classes = [
  'navbar',
  navbar_expand ? 'navbar-expand-' ~ navbar_expand : '',
  placement,
]|merge(navbar_utility_classes ?: [])
%}

{% if navbar_theme %}
  {% set nav_attributes = nav_attributes.setAttribute('data-bs-theme', navbar_theme) %}
{% endif %}

<nav {{ nav_attributes.addClass(nav_classes) }}>
  <div {{ navbar_container_attributes.addClass(navbar_container_classes) }}>

    {# Branding (logo) #}
    {% block branding %}
      {{ branding }}
    {% endblock %}

    {# RIGHT-SIDE ALWAYS-VISIBLE CONTROLS (outside collapse) #}
    <div class="ms-auto d-flex align-items-center order-lg-3 navbar-icons">

      {# Social icons group (your right region output) #}
      <div class="navbar-social d-flex align-items-center">
        {% block right %}
          {{ right }}
        {% endblock %}
      </div>

      {# Divider between socials and user icon #}
      <span class="navbar-divider" aria-hidden="true"></span>

      {# Account toggle (avatar or fallback icon) #}
      <button
        class="btn btn-link nav-link p-0 border-0 d-flex align-items-center"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#accountPanel"
        aria-expanded="false"
        aria-controls="accountPanel"
        aria-label="Account"
      >
        {% if account_avatar_url %}
          <img
            src="{{ account_avatar_url }}"
            alt="{{ (account_display_name ?: 'Account')|e }}"
            class="rounded-circle account-avatar"
          />
        {% else %}
          {# SVG fallback icon (no icon library required) #}
          <svg xmlns="http://www.w3.org/2000/svg"
               width="20" height="20"
               fill="currentColor"
               viewBox="0 0 16 16">
            <path d="M8 8a3 3 0 1 0-2.995-3.176A3 3 0 0 0 8 8z"/>
            <path fill-rule="evenodd"
                  d="M14 14s-1-4-6-4-6 4-6 4 1 1 6 1 6-1 6-1z"/>
          </svg>
        {% endif %}
      </button>

      {# Hamburger toggle (keep it near right controls) #}
      {% block navbar_toggler %}
        <button class="navbar-toggler collapsed"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target=".navbar-collapse"
                aria-controls="navbar-collapse"
                aria-expanded="false"
                aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
      {% endblock %}

    </div>

    {# Slide-down panel for account (positioned relative to container) #}
    <div id="accountPanel" class="collapse account-panel">
      <div class="account-panel__inner shadow">
        {% if logged_in %}
          <div class="account-panel__header">
            <div class="account-panel__name">
              {{ account_display_name ?: 'My account' }}
            </div>
          </div>
          <div class="account-panel__body">
            <a class="account-panel__link" href="{{ path('user.page') }}">My account</a>
            <a class="account-panel__link" href="{{ path('user.logout') }}">Log out</a>
          </div>
        {% else %}
          <div class="account-panel__body">
            <a class="account-panel__link" href="{{ path('user.login') }}">Log in</a>
            <a class="account-panel__link" href="{{ path('user.register') }}">Register</a>
          </div>
        {% endif %}
      </div>
    </div>

    {# Collapsible nav content (main menu) #}
    <div class="collapse navbar-collapse order-lg-2 w-100">
      <div class="navbar-left flex-grow-1 min-w-0">
        {% block left %}
          {{ left }}
        {% endblock %}
      </div>
    </div>

  </div>
</nav>
