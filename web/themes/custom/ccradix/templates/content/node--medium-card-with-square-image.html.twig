{#
/**
 * Node template for view mode: medium-card-with-square-image
 * Supports:
 *  - Articles (field_news_type)
 *  - Insights (field_channel)
 */
#}

{# --------------------------------------------------
   Resolve taxonomy term (News Type OR Channel)
   -------------------------------------------------- #}
{% set taxonomy_term = null %}

{% if node.field_news_type is defined and not node.field_news_type.isEmpty() and node.field_news_type.entity %}
  {% set taxonomy_term = node.field_news_type.entity %}
{% elseif node.field_channel is defined and not node.field_channel.isEmpty() and node.field_channel.entity %}
  {% set taxonomy_term = node.field_channel.entity %}
{% endif %}

{# Build taxonomy-based classes #}
{% set taxonomy_classes = [] %}
{% if taxonomy_term %}
  {% set taxonomy_classes = [
    'news-type--' ~ taxonomy_term.label|clean_class,
    'news-type--tid-' ~ taxonomy_term.id()
  ] %}
{% endif %}

{%
  set node_classes = [
  'node',
  'teaser',
  'teaser--card',
  'view-mode--' ~ view_mode|clean_class,
  node.bundle|clean_class,
  node.isPromoted() ? 'node--promoted',
  node.isSticky() ? 'node--sticky',
  not node.isPublished() ? 'node--unpublished',
]|merge(taxonomy_classes)
%}

<article{{ attributes.addClass(node_classes) }}>

  {# ---------------- Media ---------------- #}
  <div class="teaser__media">
    <a href="{{ url }}" aria-label="{{ label }}">
      {% if content.field_teaser_media is defined and content.field_teaser_media|render %}
        {{ content.field_teaser_media }}
      {% elseif content.field_news_image is defined and content.field_news_image|render %}
        {{ content.field_news_image }}
      {% elseif content.field_image is defined and content.field_image|render %}
        {{ content.field_image }}
      {% endif %}
    </a>
  </div>

  {# ---------------- Content ---------------- #}
  <div class="teaser__content">

    {{ title_prefix }}

    {# Optional external link (Exhibitor Spotlight) #}
    {% set cs_link = null %}
    {% if node.field_cs_link is defined and node.field_cs_link.uri %}
      {% set cs_link = node.field_cs_link.uri %}
    {% endif %}

    <h2 class="teaser__headline">
      {% if cs_link %}
        <a href="{{ cs_link }}" target="_blank" rel="noopener">
          {{ label }}
        </a>
      {% else %}
        <a href="{{ url }}">
          {{ label }}
        </a>
      {% endif %}
    </h2>

    {{ title_suffix }}

    {# ---------------- Meta ---------------- #}
    <footer class="teaser__authored">
      <span class="date">{{ node.getCreatedTime|date('d/m/Y') }}</span>

      {% if taxonomy_term %}
        <span class="sep"> | </span>
        <span class="news-type">
          <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': taxonomy_term.id()}) }}">
            {{ taxonomy_term.label }}
          </a>
        </span>
      {% endif %}
    </footer>

    {# Prevent duplicate field output #}
    {{ content|without(
      'field_teaser_media',
      'field_news_image',
      'field_image',
      'field_news_type',
      'field_channel',
      'field_teaser_text',
      'field_cs_link'
    ) }}

  </div>
</article>
